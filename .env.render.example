# Render-specific environment template
# Copy values into Render Dashboard -> Environment
# Do not commit real secrets.

SECRET_KEY=
FLASK_ENV=production
DEBUG=false

ADMIN_USERNAME=admin
ADMIN_PASSWORD=
POLICE_USERNAME=police
POLICE_PASSWORD=
POLICE_ACCESS_TOKEN=

# Use a valid PostgreSQL DSN only.
# Example format:
# postgresql://user:password@host:6543/postgres?sslmode=require
# Do NOT append unsupported query params like "supa".
DATABASE_URL=

# Optional media storage (recommended in production)
CLOUDINARY_URL=

# Optional shared cache
REDIS_URL=
ML_CACHE_TTL_SECONDS=86400

# Optional external ML service for serverless-safe inference
ML_SERVICE_URL=
ML_SERVICE_TIMEOUT_SECONDS=30
